# ========================================
# Supabase（登录 / 注册 / 重置密码）
# ========================================
# 控制台: https://supabase.com/dashboard → 你的项目 → Settings → API
# Project URL 填入下方；anon / public key 填入 ANON_KEY（勿把 service_role 暴露到前端）
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# 可选：仅服务端管理用途，勿提交到前端
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 在 Supabase → Authentication → URL Configuration 中添加 Redirect URLs，例如：
#   http://localhost:3000/auth/callback
#   https://你的域名/auth/callback
# Site URL 建议设为生产地址或 http://localhost:3000（开发）

# ========================================
# 火山引擎 API 配置
# ========================================

# 主 API Key - 统一用于文本生成、图片生成、视频生成
# 文本生成: Chat API (豆包对话模型)
# 图片生成: Doubao Seedream 模型
# 视频生成: Seedance 模型
ARK_API_KEY=your-volcengine-api-key

# 备用名称 (内部将 ARK_API_KEY 映射到此变量)
# 代码中使用 VOLCENGINE_API_KEY，实际配置时设置 ARK_API_KEY 即可
VOLCENGINE_API_KEY=your-volcengine-api-key

# 豆包对话模型的 endpoint ID (用于文本生成/对话)
# 在火山引擎控制台创建推理接口后获取
ARK_ENDPOINT_ID=your-doubao-endpoint-id

# ========================================
# 可选配置 (有默认值，通常不需要修改)
# ========================================

# 视频生成模型配置
# SEEDANCE_MODEL=doubao-seedance-1-5-pro-251215
# SEEDANCE_LITE_MODEL=doubao-seedance-1-0-pro-250528  # 支持首尾帧生视频（r2v 模式）
# SEEDANCE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 图片生成模型配置
# IMAGE_MODEL=doubao-seedream-5-0-260128
# IMAGE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# ========================================
# 快速开始
# ========================================
# 1. 复制此文件为 .env.local:
#    cp .env.example .env.local
#
# 2. 替换 your-volcengine-api-key 为你的真实 API Key
#    替换 your-doubao-endpoint-id 为你的真实 endpoint ID
#
# 3. 重启开发服务器:
#    npm run dev
# ========================================

